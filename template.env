# ============================================================
# MAVPlot — Environment Variables Template
# ============================================================
# IMPORTANT: Copy this file to .env and fill in your values.
#   cp template.env .env
#
# !! NEVER commit .env to version control. !!
# !! .env is listed in .gitignore for this reason. !!
# !! This template.env file contains NO real secrets. !!
# ============================================================

# Your OpenRouter API key (required).
# Get one at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# The model to use, in OpenRouter format: <provider>/<model-name>
# Browse all available models at: https://openrouter.ai/models
#
# Recommended options:
#   openai/gpt-3.5-turbo        — fast, cheap, good for most plots
#   openai/gpt-4o               — best quality, higher cost
#   anthropic/claude-3-haiku    — fast and inexpensive alternative
#   google/gemini-flash-1.5     — large context, good for long logs
OPENROUTER_MODEL=openai/gpt-3.5-turbo
