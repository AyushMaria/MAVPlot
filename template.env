# ============================================================
# MAVPlot — Environment Variables Template
# ============================================================
# IMPORTANT: Copy this file to .env and fill in your values.
#   cp template.env .env
#
# !! NEVER commit .env to version control. !!
# !! .env is listed in .gitignore for this reason. !!
# !! This template.env file contains NO real secrets. !!
# ============================================================

# Your OpenAI API key (required)
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# The OpenAI model to use for code generation.
# Options: gpt-3.5-turbo, gpt-4, gpt-4o, gpt-4-turbo
OPENAI_MODEL=gpt-3.5-turbo
